{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ci.events",
  "type": "object",
  "required": ["schema_version", "idempotency_key", "correlation_id", "produced_at", "event_type"],
  "properties": {
    "schema_version": { "type": "string" },
    "idempotency_key": { "type": "string" },
    "correlation_id": { "type": "string" },
    "produced_at": { "type": "string", "format": "date-time" },
    "event_type": { "type": "string", "enum": ["test_result", "build_status"] },
    "repo": { "type": "string" },
    "commit_sha": { "type": "string" },
    "test_result": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["passed", "failed", "skipped"] },
        "suite": { "type": "string" },
        "test": { "type": "string" },
        "file": { "type": "string" },
        "line": { "type": "integer" }
      }
    },
    "build_status": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["passed", "failed"] },
        "job": { "type": "string" }
      }
    }
  }
}
