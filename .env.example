# Core infra credentials
POSTGRES_USER=brain
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=brain
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# OpenTelemetry (OTLP/HTTP)
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318

# GitHub App bridge
GITHUB_BRIDGE_ENABLED=true
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_APP_ID=YOUR_GITHUB_APP_ID
GITHUB_INSTALLATION_ID=YOUR_INSTALLATION_ID
GITHUB_TARGET_REPO=owner/repo
GITHUB_CHECK_NAME=KA-CHOW Policy Gate
GITHUB_DELIVERY_MAX_ATTEMPTS=3
GITHUB_DELIVERY_RETRY_BASE_DELAY_MS=500
GITHUB_APP_PRIVATE_KEY_FILE=./your-private-key.pem

# Security hardening
GITHUB_BRIDGE_ADMIN_TOKEN=CHANGE_ME_LONG_RANDOM
GITHUB_WEBHOOK_SECRET=CHANGE_ME_LONG_RANDOM
TENANT_METADATA_ENCRYPTION_KEY=GENERATE_WITH_FERNET

GITHUB_TENANT_RATE_LIMIT_PER_MINUTE=120
GITHUB_TENANT_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
GITHUB_TENANT_CIRCUIT_BREAKER_COOLDOWN_SEC=120
