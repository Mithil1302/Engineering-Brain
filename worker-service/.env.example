# ==============================================================================
# KA-CHOW Worker Service Environment Configuration
# ==============================================================================
# This file documents all environment variables used by worker-service.
# Copy this file to .env and fill in your actual values.
# ==============================================================================

# ------------------------------------------------------------------------------
# GitHub App Configuration (REQUIRED for ingestion pipeline)
# ------------------------------------------------------------------------------

# REQUIRED
# GitHub App ID - Find this in your GitHub App settings page
# Example: 123456
GITHUB_APP_ID=

# REQUIRED
# GitHub App Private Key - PEM format with escaped newlines
# Find this in your GitHub App settings, generate a new private key if needed
# Format: Multi-line PEM string with \n escape sequences
# Example: "-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# REQUIRED
# GitHub App Installation ID - Find this in the installation URL after installing the app
# Example: 12345678
GITHUB_INSTALLATION_ID=

# REQUIRED
# GitHub Webhook Secret - Set this in your GitHub App webhook configuration
# Used for HMAC-SHA256 signature verification of incoming webhook events
GITHUB_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# Slack Integration (REQUIRED for Slack adapter)
# ------------------------------------------------------------------------------

# REQUIRED
# Slack Signing Secret - Find this in your Slack App settings under "Basic Information"
# Used for verifying incoming Slack webhook requests
SLACK_SIGNING_SECRET=

# REQUIRED
# Slack Bot Token - Find this in your Slack App settings under "OAuth & Permissions"
# Should start with "xoxb-"
SLACK_BOT_TOKEN=

# ------------------------------------------------------------------------------
# Google Gemini API Configuration (REQUIRED for LLM and embeddings)
# ------------------------------------------------------------------------------

# REQUIRED
# Google Gemini API Key - Get this from Google AI Studio or Google Cloud Console
# Used for both LLM generation and text embeddings
GEMINI_API_KEY=

# OPTIONAL (default: gemini-2.0-flash)
# LLM model to use for text generation
LLM_MODEL=gemini-2.0-flash

# OPTIONAL (default: 0.3)
# LLM temperature for generation (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.3

# OPTIONAL (default: 8192)
# Maximum output tokens for LLM generation
LLM_MAX_OUTPUT_TOKENS=8192

# OPTIONAL (default: text-embedding-004)
# Embedding model to use for vector embeddings (768 dimensions)
EMBEDDING_MODEL=text-embedding-004

# ------------------------------------------------------------------------------
# PostgreSQL Database Configuration
# ------------------------------------------------------------------------------

# OPTIONAL (default: postgres)
# PostgreSQL host
POSTGRES_HOST=postgres

# OPTIONAL (default: 5432)
# PostgreSQL port
POSTGRES_PORT=5432

# OPTIONAL (default: brain)
# PostgreSQL username
POSTGRES_USER=brain

# OPTIONAL (default: brain)
# PostgreSQL password
POSTGRES_PASSWORD=brain

# OPTIONAL (default: brain)
# PostgreSQL database name
POSTGRES_DB=brain

# ------------------------------------------------------------------------------
# Neo4j Graph Service Configuration
# ------------------------------------------------------------------------------

# OPTIONAL (default: graph-service:50051)
# gRPC endpoint for Neo4j graph service
# Format: host:port
GRAPH_SERVICE_URL=graph-service:50051

# ------------------------------------------------------------------------------
# Apache Kafka Configuration
# ------------------------------------------------------------------------------

# OPTIONAL (default: kafka:9092)
# Comma-separated list of Kafka broker addresses
KAFKA_BROKERS=kafka:9092

# OPTIONAL (default: repo.events)
# Kafka topic for incoming repository events (pull_request, push)
POLICY_INPUT_TOPIC=repo.events

# OPTIONAL (default: pr.checks)
# Kafka topic for outgoing policy check results
POLICY_OUTPUT_TOPIC=pr.checks

# OPTIONAL (default: docs.refresh)
# Kafka topic for documentation refresh events
POLICY_DOC_REFRESH_TOPIC=docs.refresh

# OPTIONAL (default: docs.rewrite)
# Kafka topic for documentation rewrite events
POLICY_DOC_REWRITE_TOPIC=docs.rewrite

# OPTIONAL (default: worker-policy-checks-v1)
# Kafka consumer group ID for policy pipeline
POLICY_CONSUMER_GROUP=worker-policy-checks-v1

# ------------------------------------------------------------------------------
# Ingestion Pipeline Configuration
# ------------------------------------------------------------------------------

# OPTIONAL (default: 10)
# Maximum concurrent GitHub API file fetch requests
# Higher values = faster ingestion but more API rate limit pressure
INGESTION_MAX_CONCURRENT_FETCHES=10

# OPTIONAL (default: 500)
# Maximum file size in kilobytes to ingest
# Files larger than this are skipped
INGESTION_MAX_FILE_SIZE_KB=500

# OPTIONAL (default: 50)
# Batch size for embedding upserts to pgvector
# Must not exceed Gemini API batch limit
INGESTION_BATCH_SIZE=50

# ------------------------------------------------------------------------------
# Policy Pipeline Configuration
# ------------------------------------------------------------------------------

# OPTIONAL (default: true)
# Enable or disable the policy pipeline
# Set to "false" to disable policy checks entirely
POLICY_PIPELINE_ENABLED=true

# OPTIONAL (default: rules-v1)
# Policy rule set identifier
POLICY_RULE_SET=rules-v1

# OPTIONAL (default: unknown-service)
# Default service ID when service cannot be determined
POLICY_DEFAULT_SERVICE_ID=unknown-service

# OPTIONAL (default: true)
# Enable automatic documentation refresh on policy violations
POLICY_DOC_REFRESH_ENABLED=true

# ------------------------------------------------------------------------------
# Alert Thresholds (Policy Reporting)
# ------------------------------------------------------------------------------

# OPTIONAL (default: 25)
# Failure rate percentage threshold for emitting alerts
EMIT_ALERT_FAILURE_RATE_THRESHOLD_PCT=25

# OPTIONAL (default: 10)
# Backlog growth delta threshold for emitting alerts
EMIT_ALERT_BACKLOG_GROWTH_DELTA=10

# OPTIONAL (default: 50)
# Absolute backlog size threshold for emitting alerts
EMIT_ALERT_BACKLOG_THRESHOLD=50

# OPTIONAL (default: 300)
# Oldest backlog item age in seconds threshold for emitting alerts
EMIT_ALERT_BACKLOG_OLDEST_AGE_SEC=300

# OPTIONAL (default: 5)
# Delivery failures threshold for emitting alerts
EMIT_ALERT_DELIVERY_FAILURES_THRESHOLD=5

# ------------------------------------------------------------------------------
# Security Configuration
# ------------------------------------------------------------------------------

# OPTIONAL (default: empty string)
# Signing key for auth context HMAC verification
# Leave empty to disable auth context verification (development only)
AUTH_CONTEXT_SIGNING_KEY=

# ==============================================================================
# End of Configuration
# ==============================================================================
